# Copy this file to .env.local on your computer.

# Required for real thesis generation through OpenRouter.
# Create key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Pick one default model. You can still choose DeepSeek/Qwen/Llama in the UI.
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3.1

# Optional app URL during local testing.
APP_URL=http://localhost:3000

# Supabase project settings.
# Supabase Project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=
# Public anon key: safe for browser usage.
SUPABASE_ANON_KEY=
# Service role key: server-side only. Never expose this in index.html.
SUPABASE_SERVICE_ROLE_KEY=

# Optional crawler API keys.
SEMANTIC_SCHOLAR_API_KEY=
CORE_API_KEY=
